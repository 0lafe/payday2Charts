<% unless (params[:controller] == 'jeopardy_games') && (params[:action] != 'index') %>
  <div data-controller="slideover">
    <div class="bg-dark-light flex flex-row justify-between h-10 sticky top-0 z-10">
      <div class="p-1 flex justify-between w-full lg:hidden">
        <button data-action="click->slideover#open">
          <%= image_tag("icons/bar-menu.svg", class: "w-8") %>
        </button>
        <%= render "shared/nav_bar_profile" %>
      </div>

      <div class="hidden lg:flex lg:flex-row">
        <%= link_to "Leaderboards",
          root_path,
          data: { turbo: false },
          class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if params[:controller] == 'leaderboards'}" %>
        <%= link_to "Community Charts",
          charts_path,
          data: { turbo: false },
          class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if current_page?(controller: 'charts', action: 'index')}" %>
        <% if current_user && current_user.me? %>
          <%= link_to "Skins",
            skins_path,
            data: { turbo: false },
            class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if params[:controller] == 'skins'}" %>
        <% end %>
        <%= link_to "Guess Who",
          guess_whos_path,
          data: { turbo: false },
          class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if params[:controller] == 'guess_whos'}" %>
        <%= link_to "Gifs",
          gifs_path,
          data: { turbo: false },
          class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if params[:controller] == 'gifs'}" %>
        <%= link_to "Crit Calculator",
          crits_path,
          data: { turbo: false },
          class: "px-4 h-full flex items-center hover:bg-white hover:text-black #{'bg-branding-blue' if params[:controller] == 'crits'}" %>
      </div>

      <div class="hidden lg:flex lg:flex-row">
        <a href="https://github.com/0lafe/payday2Charts/issues" target="_blank" class="px-4 h-full flex items-center hover:bg-white hover:text-black">
          Report Bugs Here
          <i class="fa-solid fa-up-right-from-square" style="margin-left: 0.5rem;"></i>
        </a>
        <%= render "shared/nav_bar_profile" %>
      </div>
    </div>
    
    <div data-slideover-target="panel" class="flex flex-col justify-between w-3/4 p-4 z-30 bg-dark-light fixed inset-y-0 left-0 shadow-lg transform -translate-x-full transition-transform duration-150">
      <div>
        <div class="flex justify-between mb-4">
          <div class="text-xl">Pages</div>
          <button data-action="click->slideover#close">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <div class="flex flex-col gap-1">
          <%= link_to "Leaderboards",
            root_path,
            data: { turbo: false },
            class: "p-2 #{'bg-branding-blue' if params[:controller] == 'leaderboards'}" %>
          <%= link_to "Community Charts",
            charts_path,
            data: { turbo: false },
            class: "p-2 #{'bg-branding-blue' if params[:controller] == 'charts'}" %>
          <%= link_to "Guess Who",
            guess_whos_path,
            data: { turbo: false },
            class: "p-2 #{'bg-branding-blue' if params[:controller] == 'guess_whos'}" %>
          <%= link_to "Gifs",
            gifs_path,
            data: { turbo: false },
            class: "p-2 #{'bg-branding-blue' if params[:controller] == 'gifs'}" %>
          <%= link_to "Crit Calculator",
            crits_path,
            data: { turbo: false },
            class: "p-2 #{'bg-branding-blue' if params[:controller] == 'crits'}" %>
          <% if current_user && current_user.me? %>
            <%= link_to "Skins",
              skins_path,
              data: { turbo: false },
              class: "p-2 #{'bg-branding-blue' if params[:controller] == 'skins'}" %>
          <% end %>
        </div>
      </div>

      <%= link_to "https://github.com/0lafe/payday2Charts/issues", target: "_blank", class: "flex gap-2 items-center p-2 justify-center" do %>
        <%= image_tag("icons/github-white.svg", class: "h-8") %>
        Report Bugs Here
        <i class="fa-solid fa-up-right-from-square" style="margin-left: 0.5rem;"></i>
      <% end %>
    </div>
    <div data-slideover-target="backdrop" class="fixed inset-0 z-20 bg-black/50 hidden"></div>
  </div>
<% end %>

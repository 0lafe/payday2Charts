<div data-controller="dropdown-search" class="relative text-white w-full">
  <button
    data-action="click->dropdown-search#toggle"
    data-dropdown-search-target="button"
    class="w-full rounded-t-xl rounded-b-xl border border-white/10 bg-dark-inputs px-4 py-3 focus:border-branding-blue focus:ring-2 focus:ring-brandingborder-branding-blue/30 flex justify-between"
  >
    <span data-chart-page-target="label">Melee Kills</span>
    <span>▾</span>
  </button>

  <div
    data-dropdown-search-target="menu"
    class="absolute z-10 left-0 w-full bg-dark-light border border-branding-blue/40 rounded shadow-lg hidden"
  >
    <input
      type="text"
      placeholder="Search..."
      data-action="input->dropdown-search#filter"
      data-dropdown-search-target="input"
      class="w-full px-3 py-2 bg-dark-inputs text-white border-b border-gray-700 outline-none"
    />

    <ul class="max-h-48 overflow-y-auto bg-branding-blue/10">
      <% @options.each do |item| %>
        <li
          data-dropdown-search-target="item"
          data-label="<%= item[0] %>"
          data-value="<%= item[1] %>"
          data-action="click->dropdown-search#toggle click->chart-page#select"
          class="px-4 py-2 cursor-pointer hover:bg-gray-700"
        >
          <%= item[0] %>
        </li>
      <% end %>
    </ul>
  </div>
</div>

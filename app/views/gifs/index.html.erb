<div class="page">
  <div class="gifs-page">
    <div class="portlet-container">
      <div>
        <h1>Gifs</h1>
        <hr/>
        <p>Paste these links into discord for a silly method of sharing files</p>
        <p>They display as gifs when embeded in discord, but visiting the link will prompt a download</p>
      </div>
    </div>
    <div data-controller="gifs" class="gifs-container">
      <% DownloadGif.all.each do |gif| %>
        <div class="gif-row">
          <div class="gif-title">
            <h1><%= gif.name.titleize %></h1>
            <h3 data-bs-toggle="tooltip" title="Copy" data-bs-placement="top">
              <i class="fa-solid fa-clipboard copy-link"></i>
              <span>
                <%= "https://payday-charts.com/gifs/#{gif.name}.gif" %>
              </span>
            </h3>
          </div>
          <div class="gif-image">
            <div>
              <%= image_tag("gifs/#{gif.name}.gif") %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if @guess_who.game_type == "heist" %>
    <%= image_tag("guess_who/heists/#{item}",
        class: "w-64 select-none pointer-events-none m-auto") %>
<% elsif @guess_who.game_type == "skins" %>
    <%= image_tag("https://www.overkillsoftware.com/ovk-media/economy42gF2Y/#{item}.png",
        style: "max-width:100%;padding: 1rem 0;",
        class: "guess_who_card rarity-background #{GuessWho.skin_data(item)["rarity"]}") %>
<% elsif @guess_who.game_type == "content_creators" %>
    <%= image_tag("guess_who/content_creators/#{item}",
        style: "width:120px;height:140px;padding: 1rem 0;",
        class: "guess_who_card") %>
<% elsif @guess_who.game_type == "characters" %>
    <%= image_tag("guess_who/characters/#{item}.png",
    style: "width:120px;height:140px;padding: 1rem 0;",
    class: "guess_who_card") %>
<% else %>
    <img src="<%= item %>",
        class="w-64 select-none pointer-events-none m-auto" draggable="false" />
<% end %>
<div class="bg-dark-main flex items-center justify-center p-6" data-controller="guess-who-index">
  <div class="w-full max-w-sm space-y-6">

    <div class="space-y-5">
      <%= render TileComponent.new(title: "Guess Who!") do %>
        <div class="space-y-4">
          <div class="text-sm text-zinc-400 mt-1">
            A silly little guessing game to play with friends
          </div>

          <%= simple_form_for :search, html: { data: { action: 'submit->guess-who-index#join' } } do |f| %>
            <%= f.input :id, as: :numeric, label: "Game ID:", input_html: { 'data-guess-who-index-target': 'joinCode' } %>
            <%= f.submit "Join Game", class: "btn-primary w-full" %>
          <% end %>

          <div class="h-px bg-white/10"></div>

          <button class="btn-primary w-full" data-action="click->guess-who-index#showForm">New Game</button>
          <div class="hidden" data-guess-who-index-target="newGameForm">
            <%= simple_form_for GuessWho.new do |f| %>
              <%= f.input :game_type, collection: GuessWho.game_types, input_html: { style: "width:100%;height:2rem;" }, required: true %>
              <%= f.submit 'Create Game', class: "btn-primary w-full" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

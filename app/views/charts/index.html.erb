<div data-controller="chart-page" class="m-4">
    <%= render TileComponent.new do %>
        <div class="flex justify-between flex-col md:flex-row gap-2">
            <div class="flex gap-4 items-center">
                <button data-action="click->chart-page#navigateStart" class="pagination-arrow paginate-back">
                    &lt;&lt;&lt;
                </button>
                <button data-action="click->chart-page#navigatePrevious" class="pagination-arrow paginate-back">
                    &lt;
                </button>
                
                <div data-chart-page-target="paginationNumbers" class="flex gap-2 items-center"></div>
                
                <button data-action="click->chart-page#navigateNext" class="pagination-arrow paginate-forward">
                    &gt;
                </button>
                <button data-action="click->chart-page#navigateEnd" class="pagination-arrow paginate-forward">
                    &gt;&gt;&gt;
                </button>
            </div>

            <div class="w-80">
                <%= render ChartSearchComponent.new %>
            </div>

            <div>
                <span>Search</span>
                <input data-action="input->chart-page#search"
                    class="flex-1 rounded-xl border border-white/10 bg-dark-inputs px-4 py-3 text-zinc-100 placeholder:text-zinc-500 outline-none transition focus:border-branding-blue focus:ring-2 focus:ring-branding-blue/30"/>
            </div>
        </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-3 3xl:grid-cols-4 gap-4 mt-4" data-chart-page-target="container">
        <%= render TileComponent.new do %>
            <div class="loader mx-auto"></div>
            <div class="content space-y-2 hidden">
                <div class="flex gap-2 justify-between items-center">
                    <div class="flex flex-col gap-2 w-1/3">
                        <span class="name"></span>
                        <span class="total"></span>
                        <span class="rank"></span>
                    </div>
                    <div class="image h-32"></div>
                </div>
                <canvas class="max-h-32 3xl:max-h-64"></canvas>
            </div>
        <% end %>
    </div>
</div>
<% if params[:controller] == "homes" %>
  <meta property="og:description" content="Global Payday 2 Statistics">
<% elsif params[:controller] == "leaderboards" %>
  <% if params[:action] == "show" %>
    <meta property="og:description" content="<%= @name %> Leaderboard">
  <% elsif params[:action] == "top_100" %>
    <% if @leaderboard_user.present? %>
      <meta property="og:description" content="Top 100 for <%= @leaderboard_user.name %>">
    <% else %>
      <meta property="og:description" content="Nonexistant Top 100">
    <% end %>
  <% else %>
    <meta property="og:description" content="Payday 2 Leaderboards">
  <% end %>
<% elsif params[:controller] == "guess_whos" %>
  <% if params[:action] == "index" %>
    <meta property="og:description" content="Payday 2 Guess Who">
  <% else %>
    <meta property="og:description" content="Guess Who: <%= @guess_who.game_type.titleize %>">
  <% end %>
<% end %>